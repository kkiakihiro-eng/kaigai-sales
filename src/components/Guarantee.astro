---
// Guarantee - Meeting guarantee section
const guaranteeDetails = [
  'Standard以上のプランで、月間保証件数に達しなかった場合、翌月に追加稼働を無償で実施',
  'オンライン商談のセッティング完了をもって1件とカウント',
  '契約後2ヶ月目以降に適用（初月はリスト構築・戦略策定期間）',
];
---

<section class="bg-secondary text-white reveal">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div>
        <span class="text-sm text-primary font-bold uppercase tracking-wider">Guarantee</span>
        <h2 class="text-2xl md:text-3xl font-bold mt-2 mb-4">
          成果が出なかったら？<br />
          <span class="text-primary">商談保証制度</span>があります。
        </h2>
        <p class="text-white/70 mb-6 leading-relaxed">
          海外営業の「やってみたけど成果ゼロ」というリスクを最小化。<br />
          商談件数を保証することで、安心してスタートできます。
        </p>

        <ul class="space-y-4">
          {guaranteeDetails.map((detail) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
              <span class="text-white/80 text-sm">{detail}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-2xl p-8 backdrop-blur-sm">
        <h3 class="text-lg font-bold mb-6 text-center">プラン別 商談保証件数</h3>
        <div class="space-y-4">
          <div class="flex items-center justify-between p-4 rounded-xl bg-white/5">
            <div>
              <p class="font-bold">Lite プラン</p>
              <p class="text-white/50 text-sm">月額 約10万円</p>
            </div>
            <span class="text-white/40 text-sm">保証なし</span>
          </div>

          <div class="flex items-center justify-between p-4 rounded-xl bg-primary/10 border border-primary/30">
            <div>
              <p class="font-bold text-primary">Standard プラン</p>
              <p class="text-white/50 text-sm">月額 約16万円</p>
            </div>
            <div class="text-right">
              <span class="text-primary font-bold text-xl">月3件</span>
              <p class="text-white/50 text-xs">商談保証</p>
            </div>
          </div>

          <div class="flex items-center justify-between p-4 rounded-xl bg-white/5">
            <div>
              <p class="font-bold">Premium プラン</p>
              <p class="text-white/50 text-sm">月額 約22万円</p>
            </div>
            <div class="text-right">
              <span class="text-white font-bold text-xl">月5件</span>
              <p class="text-white/50 text-xs">商談保証</p>
            </div>
          </div>
        </div>

        <div class="mt-6 text-center">
          <a href="#contact" class="inline-flex items-center justify-center bg-primary hover:bg-primary-dark text-white font-bold py-3 px-6 rounded-lg transition-colors w-full">
            まずは無料で相談する
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
