---
// Header with mobile menu - Japanese only
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-border">
  <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 font-bold text-xl text-primary">
      海外セールスくん
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-6 text-sm font-medium">
      <a href="/#service" class="text-secondary hover:text-primary transition-colors">サービス</a>
      <a href="/#pricing" class="text-secondary hover:text-primary transition-colors">料金</a>
      <a href="/#flow" class="text-secondary hover:text-primary transition-colors">ご利用の流れ</a>
      <a href="/#faq" class="text-secondary hover:text-primary transition-colors">FAQ</a>
      <a href="/blog" class="text-secondary hover:text-primary transition-colors">ブログ</a>
      <a href="/#contact" class="bg-primary hover:bg-primary-dark text-white px-5 py-2 rounded-lg transition-colors font-bold">
        無料相談
      </a>
    </nav>

    <!-- Mobile menu button -->
    <button id="mobile-menu-btn" class="md:hidden p-2 text-secondary" aria-label="メニューを開く">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <nav id="mobile-menu" class="md:hidden hidden bg-white border-t border-border">
    <div class="px-4 py-4 space-y-3">
      <a href="/#service" class="block text-secondary hover:text-primary py-2">サービス</a>
      <a href="/#pricing" class="block text-secondary hover:text-primary py-2">料金</a>
      <a href="/#flow" class="block text-secondary hover:text-primary py-2">ご利用の流れ</a>
      <a href="/#faq" class="block text-secondary hover:text-primary py-2">FAQ</a>
      <a href="/blog" class="block text-secondary hover:text-primary py-2">ブログ</a>
      <a href="/#contact" class="block bg-primary text-white text-center py-3 rounded-lg font-bold mt-2">
        無料相談
      </a>
    </div>
  </nav>
</header>

<div class="h-16"></div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const icon = document.getElementById('menu-icon');
  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    icon?.setAttribute('d', isOpen ? 'M4 6h16M4 12h16M4 18h16' : 'M6 18L18 6M6 6l12 12');
  });
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      icon?.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
    });
  });
</script>
