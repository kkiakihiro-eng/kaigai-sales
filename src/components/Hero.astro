---
// Hero section - First view
---

<section class="relative bg-gradient-to-br from-secondary via-secondary to-slate-800 text-white overflow-hidden">
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-0 right-0 w-96 h-96 bg-primary rounded-full blur-3xl -translate-y-1/2 translate-x-1/3"></div>
    <div class="absolute bottom-0 left-0 w-72 h-72 bg-accent rounded-full blur-3xl translate-y-1/2 -translate-x-1/3"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-4 py-20 md:py-32">
    <div class="max-w-3xl">
      <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-4 py-2 mb-6 text-sm">
        <span class="w-2 h-2 bg-primary rounded-full animate-pulse"></span>
        ASEAN5カ国対応 | 補助金で実質月5万円〜
      </div>

      <h1 class="text-3xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6">
        御社の<span class="text-primary">"海外営業部"</span>を、<br class="hidden md:block" />
        月額制でまるごと提供。
      </h1>

      <p class="text-lg md:text-xl text-white/80 mb-8 max-w-2xl leading-relaxed">
        ASEAN専門チーム30名が、営業リスト作成からアポ獲得まで代行。英語が話せなくても、海外の商談が取れる。
      </p>

      <div class="flex flex-col sm:flex-row gap-4">
        <a href="#contact" class="inline-flex items-center justify-center bg-primary hover:bg-primary-dark text-white font-bold py-4 px-8 rounded-lg text-lg transition-colors shadow-lg shadow-primary/30">
          無料で相談する
        </a>
        <a href="#service" class="inline-flex items-center justify-center bg-white/10 hover:bg-white/20 text-white font-bold py-4 px-8 rounded-lg text-lg transition-colors border border-white/20">
          サービスを詳しく見る
        </a>
      </div>

      <div class="flex flex-wrap gap-6 mt-10 text-sm text-white/60">
        <div class="flex items-center gap-2">
          <span class="text-primary font-bold text-2xl">20万件+</span>
          <span>営業データベース</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-primary font-bold text-2xl">5カ国</span>
          <span>ASEAN対応</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-primary font-bold text-2xl">30名</span>
          <span>専門チーム体制</span>
        </div>
      </div>

      <!-- Client trust indicators -->
      <div class="mt-10 pt-8 border-t border-white/10">
        <p class="text-xs text-white/40 mb-4">取引実績のある業種</p>
        <div class="flex flex-wrap gap-3">
          {['製造業', '食品メーカー', 'IT企業', 'HR・人材', 'マーケティング', '貿易・商社'].map(industry => (
            <span class="px-3 py-1.5 bg-white/5 border border-white/10 rounded-full text-xs text-white/50">
              {industry}
            </span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
