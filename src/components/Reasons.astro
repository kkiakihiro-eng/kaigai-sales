---
// Reasons - Why customers choose us (3 key differentiators)
const reasons = [
  {
    number: '01',
    title: 'ASEAN専門チーム30名体制',
    description: 'タイ・バンコクに自社拠点を持ち、現地市場を熟知したバイリンガルスタッフが対応。タイ語・英語・ベトナム語など現地語でのアプローチが可能です。',
    highlight: '自社拠点 × 現地語対応',
  },
  {
    number: '02',
    title: '商談保証制度',
    description: '万が一、月間の保証件数に達しなかった場合、翌月に追加稼働を無償で実施。「やったけど成果ゼロ」というリスクを最小化します。',
    highlight: 'Standard: 月3件 / Premium: 月5件',
  },
  {
    number: '03',
    title: '補助金で実質月5万円〜',
    description: '小規模事業者持続化補助金など、各種補助金の申請サポートを無料で提供。最大2/3の補助で、低コストでの海外営業開始が可能です。',
    highlight: '申請サポート無料',
  },
];
---

<section class="reveal">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-12">
      <span class="text-sm text-primary font-bold uppercase tracking-wider">Why Us</span>
      <h2 class="text-2xl md:text-3xl font-bold mt-2 mb-4">海外セールスくんが選ばれる3つの理由</h2>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {reasons.map((reason) => (
        <div class="relative bg-white border border-border rounded-2xl p-8 hover:shadow-lg transition-shadow">
          <span class="text-5xl font-black text-primary/10 absolute top-4 right-6">{reason.number}</span>
          <div class="relative">
            <h3 class="text-xl font-bold mb-4">{reason.title}</h3>
            <p class="text-muted text-sm leading-relaxed mb-4">{reason.description}</p>
            <span class="inline-block bg-primary-light text-primary text-xs font-bold px-3 py-1.5 rounded-full">
              {reason.highlight}
            </span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
