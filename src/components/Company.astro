---
// Company section - About the operating company
---

<section class="bg-bg-alt reveal" id="company">
  <div class="max-w-4xl mx-auto px-4">
    <div class="text-center mb-12">
      <span class="text-sm text-primary font-bold uppercase tracking-wider">Company</span>
      <h2 class="text-2xl md:text-3xl font-bold mt-2 mb-4">運営会社</h2>
    </div>

    <div class="bg-white rounded-xl border border-border overflow-hidden">
      <table class="w-full text-sm">
        <tbody>
          <tr class="border-b border-border">
            <th class="text-left py-4 px-6 bg-bg-alt font-semibold w-1/3">会社名</th>
            <td class="py-4 px-6">
              株式会社Albaly / Albaly Group Co., Ltd.
            </td>
          </tr>
          <tr class="border-b border-border">
            <th class="text-left py-4 px-6 bg-bg-alt font-semibold">代表者</th>
            <td class="py-4 px-6">木本 彰宏</td>
          </tr>
          <tr class="border-b border-border">
            <th class="text-left py-4 px-6 bg-bg-alt font-semibold">設立</th>
            <td class="py-4 px-6">2021年（タイ法人） / 2024年（日本法人）</td>
          </tr>
          <tr class="border-b border-border">
            <th class="text-left py-4 px-6 bg-bg-alt font-semibold">従業員数</th>
            <td class="py-4 px-6">約30名（タイ・日本拠点合計）</td>
          </tr>
          <tr class="border-b border-border">
            <th class="text-left py-4 px-6 bg-bg-alt font-semibold">タイ拠点</th>
            <td class="py-4 px-6">
              232 M9 Square Building, 3F, Room 310,<br class="hidden md:block" />
              333 Ratchadapisek Rd, Huai Khwang, Bangkok 10310
            </td>
          </tr>
          <tr>
            <th class="text-left py-4 px-6 bg-bg-alt font-semibold">事業内容</th>
            <td class="py-4 px-6">セールスBPO / ウェビナー企画運営 / 海外進出支援</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>
