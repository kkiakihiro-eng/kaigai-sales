---
/**
 * Blog post layout with LLMO optimization
 * - Article schema (JSON-LD)
 * - FAQ schema (if frontmatter has faq)
 * - Summary box
 * - Q&A section
 */
import BaseLayout from './BaseLayout.astro';

interface FAQ {
  q: string;
  a: string;
}

interface Props {
  title: string;
  description: string;
  publishDate: string;
  updatedDate?: string;
  author?: string;
  category?: string;
  tags?: string[];
  keywords?: string[];
  faq?: FAQ[];
  summary?: string[];
}

const {
  title,
  description,
  publishDate,
  updatedDate,
  author = 'Albaly Group',
  category,
  tags = [],
  keywords = [],
  faq = [],
  summary = [],
} = Astro.props;

const siteUrl = 'https://kaigai-sales.albaly.jp';

// Article schema (LLMO)
const articleSchema: Record<string, any> = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": publishDate,
  "author": {
    "@type": "Person",
    "name": author
  },
  "publisher": {
    "@type": "Organization",
    "name": "Albaly Group Co., Ltd.",
    "url": "https://albaly.jp"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `${siteUrl}${Astro.url.pathname}`
  }
};

if (updatedDate) {
  articleSchema.dateModified = updatedDate;
}

if (keywords.length > 0) {
  articleSchema.keywords = keywords.join(', ');
}

// FAQ schema (LLMO)
const faqSchema = faq.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a
    }
  }))
} : null;

const combinedSchema = faqSchema
  ? [articleSchema, faqSchema]
  : articleSchema;
---

<BaseLayout title={title} description={description} schema={combinedSchema}>
  <article class="max-w-3xl mx-auto px-4 py-16">
    <header class="mb-8">
      {category && (
        <span class="text-sm text-brand font-medium">{category}</span>
      )}
      <h1 class="text-3xl md:text-4xl font-bold font-heading mt-2 mb-4">{title}</h1>
      <div class="flex items-center gap-4 text-sm text-muted">
        <time datetime={publishDate}>{publishDate}</time>
        {updatedDate && <time datetime={updatedDate}>({updatedDate} 更新)</time>}
        <span>{author}</span>
      </div>
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-3">
          {tags.map(tag => (
            <span class="text-xs bg-light text-primary px-2 py-1 rounded">{tag}</span>
          ))}
        </div>
      )}
    </header>

    {summary.length > 0 && (
      <div class="bg-primary-light border-l-4 border-primary rounded-r-lg p-6 mb-8">
        <h2 class="text-lg font-bold mb-3">この記事で分かること</h2>
        <ul class="space-y-2">
          {summary.map(item => (
            <li class="flex items-start gap-2">
              <span class="text-primary mt-1 font-bold">&#10003;</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    <div class="prose prose-lg max-w-none">
      <slot />
    </div>

    {faq.length > 0 && (
      <section class="mt-12 border-t border-border pt-8">
        <h2 class="text-2xl font-bold font-heading mb-6">よくある質問</h2>
        <div class="space-y-4">
          {faq.map(item => (
            <details class="border border-border rounded-lg group">
              <summary class="font-bold text-lg p-5 cursor-pointer flex items-center justify-between hover:bg-bg-alt transition-colors">
                <span>Q. {item.q}</span>
                <span class="text-muted group-open:rotate-180 transition-transform">&#9660;</span>
              </summary>
              <div class="px-5 pb-5 text-secondary">
                <p>{item.a}</p>
              </div>
            </details>
          ))}
        </div>
      </section>
    )}

    <div class="mt-12 text-center">
      <a href="/#contact" class="inline-block bg-primary hover:bg-primary-dark text-white font-bold py-3 px-8 rounded-lg transition-colors">
        無料で相談する
      </a>
    </div>
  </article>
</BaseLayout>
